# Sensitive configuration
config.json

# Database
data/app.sqlite
data/app.sqlite-wal
data/app.sqlite-shm
data/backups/*.sqlite

# Runtime import cursor files (generated by admin/import.php)
data/import_queue_*.json

# Temporary working directories
tmp/

# User media
assets/media/*
!assets/media/.gitkeep

# User-uploaded logo and generated favicons (per-installation)
assets/img/logo.png
assets/img/favicon-32.png
assets/img/favicon-64.png

# Logs
data/*.log
data/logs/

# Debug tools (remove before publishing)
diag.php
sw-clear.php

# System files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/

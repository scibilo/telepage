# =====================================================================
# TELEPAGE — .htaccess
# =====================================================================

Options -Indexes
DirectoryIndex index.php

# -----------------------------------------------------------------------
# 1. PROTEZIONE FILE SENSIBILI
# -----------------------------------------------------------------------
<Files "config.json">
    Require all denied
</Files>
<FilesMatch "\.json$">
    Require all denied
</FilesMatch>
<FilesMatch "\.(md|txt|sql|sh|log|lock)$">
    Require all denied
</FilesMatch>
<Files "reset.txt">
    Require all denied
</Files>

# -----------------------------------------------------------------------
# 2. HEADERS SICUREZZA
# -----------------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS — emesso solo su HTTPS (un browser ignorerebbe comunque l'header
    # su HTTP, ma evitiamo il rumore e non introduciamo side-effect in locale).
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

    # Permissions-Policy: Telepage non usa nessuna di queste API; la policy
    # più restrittiva le disabilita tutte, riducendo la superficie di
    # attacco se mai dovessero comparire via terze-parti (embed, iframe).
    Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"

    # Content-Security-Policy — base permissivo (admin + install + public).
    #
    # script-src includes 'unsafe-inline': admin pages have ~7 inline
    # script blocks and ~48 inline event handlers (onclick=, onsubmit=,
    # ...) accumulated organically. The public feed (index.php) also
    # has 2 inline blocks — cache cleanup + window.TELEPAGE_CONFIG
    # bootstrap — and 3 inline event handlers. Removing them all is a
    # separate, bigger refactor (see audit C6 / future work). For now
    # this CSP adds the cheap directives that don't require code
    # changes:
    #
    #   - default-src 'self'      blocks anything unspecified loaded
    #                             from a foreign origin
    #   - object-src 'none'       blocks <object>/<embed>/<applet> —
    #                             Flash is dead, plugins are an XSS
    #                             vector with no legitimate use here
    #   - frame-ancestors 'self'  defence-in-depth alongside the
    #                             existing X-Frame-Options:
    #                             SAMEORIGIN. Modern browsers prefer
    #                             this directive.
    #   - form-action 'self'      a stored XSS in admin can no longer
    #                             POST to an attacker-controlled URL
    #   - base-uri 'self'         blocks <base href=evil.com> tricks
    #                             that would re-target relative URLs
    #
    # img-src includes data: and https: so Telegram-scraped favicons
    # and remote thumbnail URLs continue to render.
    #
    # External hosts allowed:
    #   - fonts.googleapis.com (style-src) — Google Fonts CSS
    #   - fonts.gstatic.com    (font-src)  — Google Fonts WOFF2 binaries
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; base-uri 'self'"

    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf)$">
        Header set Cache-Control "max-age=86400, public"
    </FilesMatch>
</IfModule>

# -----------------------------------------------------------------------
# 3. PROTEZIONI DIRECTORY
# -----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Blocca accesso diretto a data/
    RewriteRule ^data/ - [F,L]

    # Blocca accesso diretto a directives/
    RewriteRule ^directives/ - [F,L]

    # Blocca accesso diretto a vendor/ (Composer dependencies, mai
    # serviti via HTTP ma protetti per difesa in profondità).
    RewriteRule ^vendor/ - [F,L]

    # Blocca accesso diretto a app/ (codice applicativo, dovrebbe
    # essere caricato solo via require dagli entry-point).
    RewriteRule ^app/ - [F,L]

    # Blocca accesso diretto a tests/ e bin/ (script CLI, mai web).
    RewriteRule ^tests/ - [F,L]
    RewriteRule ^bin/ - [F,L]
</IfModule>

# -----------------------------------------------------------------------
# 4. PHP
# -----------------------------------------------------------------------
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>

# -----------------------------------------------------------------------
# 5. DISABILITA CACHE SERVER per index.php (LiteSpeed, Varnish, Nginx)
# -----------------------------------------------------------------------
<IfModule mod_headers.c>
    <FilesMatch "^index\.php$">
        Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header always set Pragma "no-cache"
        Header always set Surrogate-Control "no-store"
        Header always set X-Accel-Expires "0"
        Header always unset ETag
        Header always unset Last-Modified
    </FilesMatch>
</IfModule>

# LiteSpeed Cache: escludi index.php
<IfModule LiteSpeed>
    CacheDisable /index.php
</IfModule>

# -----------------------------------------------------------------------
# 6. DISABILITA CACHE LITESPEED per TUTTI i file PHP (non solo index)
# -----------------------------------------------------------------------
<IfModule LiteSpeed>
    CacheDisable public /
    RewriteEngine On
    RewriteRule .* - [E=Cache-Control:no-cache]
</IfModule>

# Per Apache con mod_cache
<IfModule mod_cache.c>
    CacheDisable /
</IfModule>

# Forza no-cache su tutti i .php
<IfModule mod_headers.c>
    <FilesMatch "\.php$">
        Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header always set Pragma "no-cache"
        Header always set Surrogate-Control "no-store"
        Header always unset ETag
    </FilesMatch>
</IfModule>

{
    "name": "scibilo/telepage",
    "description": "Self-hosted PHP app that publishes Telegram channels as navigable websites.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo_sqlite": "*",
        "ext-curl": "*",
        "ext-mbstring": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "classmap": [
            "app/"
        ],
        "files": [
            "app/Http.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/Unit/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test-stress": "php tests/ConfigConcurrencyTest.php",
        "phpstan": "phpstan analyse",
        "phpstan-baseline": "phpstan analyse --generate-baseline --allow-empty-baseline"
    }
}
